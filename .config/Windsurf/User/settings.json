{
  "window.autoDetectColorScheme": false,
  "window.autoDetectHighContrast": false,
  "window.restoreWindows": "preserve",
  "window.titleBarStyle": "custom",
  "window.menuBarVisibility": "classic",
  "workbench.activityBar.location": "top",
  "workbench.colorCustomizations": {
    "editorInlayHint.background": "#00000000",
    "editorInlayHint.foreground": "#40434C",
    "editorInlayHint.parameterBackground": "#00000000",
    "editorInlayHint.parameterForeground": "#40434C",
    "editorInlayHint.typeBackground": "#00000000",
    "editorInlayHint.typeForeground": "#40434C",
    "editorRuler.foreground": "#333333"
  },
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.editor.decorations.colors": true,
  "workbench.editor.decorations.badges": true,
  "workbench.editor.wrapTabs": true,
  "workbench.editor.historyBasedLanguageDetection": true,
  "workbench.enableExperiments": false,
  "workbench.iconTheme": "catppuccin-mocha",
  "workbench.list.defaultFindMode": "highlight",
  "workbench.settings.enableNaturalLanguageSearch": false,
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  "breadcrumbs.enabled": true,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "explorer.confirmPasteNative": true,
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.enabled": true,
  "editor.folding": false,
  "editor.fontFamily": "'Monaspace Neon', monospace",
  // https://github.com/githubnext/monaspace#visual-studio-code
  "editor.fontLigatures": "'calt', 'liga'",
  "editor.fontSize": 15,
  "editor.guides.bracketPairs": "active",
  "editor.inlayHints.enabled": "onUnlessPressed",
  "editor.inlineSuggest.enabled": true,
  "editor.minimap.enabled": true,
  "editor.minimap.renderCharacters": false,
  "editor.renderControlCharacters": true,
  "editor.renderLineHighlight": "all",
  "editor.renderWhitespace": "all",
  "editor.rulers": [80, 100],
  "editor.semanticTokenColorCustomizations": {
    "rules": {
      "*.deprecated": {
        "strikethrough": true
      }
    }
  },
  "editor.snippetSuggestions": "top",
  "editor.suggest.matchOnWordStartOnly": false,
  "editor.suggest.preview": true,
  "editor.suggest.showStatusBar": true,
  "editor.suggestSelection": "first",
  "editor.tabSize": 2,
  "editor.unicodeHighlight.ambiguousCharacters": true,
  "editor.unicodeHighlight.invisibleCharacters": true,
  "editor.wordBasedSuggestions": "allDocuments",
  "editor.wordWrap": "on",
  "debug.confirmOnExit": "always",
  "diffEditor.ignoreTrimWhitespace": false,
  "extensions.ignoreRecommendations": true,
  "files.associations": {
    ".env.*": "properties"
  },
  "files.exclude": {
    "**/.*cache": true,
    "**/.git": true,
    "**/.jj": true
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.watcherExclude": {
    "**/.*cache": true,
    "**/.*cache/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.jj/**": true,
    "**/.turbo/**": true,
    "**/.wrangler/**": true,
    "**/*-lock.*": true,
    "**/*.bak": true,
    "**/*.bak/**": true,
    "**/*.lock": true,
    "**/build/**": true,
    "**/coverage/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true,
    "**/playwright-report/**": true,
    "**/public/**": true,
    "**/test-results/**": true,
    "**/tmp/**": true,
    "**/var/**": true,
    "**/zig-out/**": true
  },
  "search.seedWithNearestWord": true,
  "search.smartCase": true,
  "search.quickOpen.includeSymbols": false,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.detectSubmodules": false,
  "git.enableCommitSigning": true,
  "git.mergeEditor": false,
  "git.suggestSmartCommit": false,
  "scm.alwaysShowRepositories": true,
  "debug.allowBreakpointsEverywhere": false,
  "terminal.integrated.defaultProfile.linux": "bash",
  // "terminal.integrated.defaultProfile.linux": "sandbox",
  "terminal.integrated.profiles.linux": {
    "sandbox": {
      "path": "/home/max/.local/bin/sandbox.sh",
      "args": []
    }
  },
  // "terminal.integrated.shellIntegration.enabled": false,
  "task.allowAutomaticTasks": "off",
  "task.autoDetect": "off",
  "grunt.autoDetect": "off",
  "gulp.autoDetect": "off",
  "jake.autoDetect": "off",
  "npm.autoDetect": "off",
  "npm.packageManager": "bun",
  "npm.scriptRunner": "bun",
  "html.completion.attributeDefaultValue": "empty",
  "js/ts.implementationsCodeLens.enabled": true,
  "js/ts.implicitProjectConfig.checkJs": true,
  "js/ts.inlayHints.enumMemberValues.enabled": true,
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.inlayHints.parameterNames.enabled": "all",
  "js/ts.inlayHints.parameterNames.suppressWhenArgumentMatchesName": true,
  "js/ts.inlayHints.parameterTypes.enabled": true,
  "js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
  "js/ts.inlayHints.variableTypes.enabled": true,
  "js/ts.referencesCodeLens.enabled": true,
  "js/ts.tsc.autoDetect": "off",
  "js/ts.tsserver.npm.path": "bun",

  "biome.requireConfiguration": true,
  "biome.suggestInstallingGlobally": false,
  "claudeCode.preferredLocation": "panel",
  "githubPullRequests.pullBranch": "never",
  "harper.codeActions.ForceStable": true,
  // "harper.dialect": "British",
  "zig.path": "zig",
  "zig.zls.enabled": "on",
  "zig.zls.path": "zls",
  "zig.zls.warnStyle": true,
  "[markdown]": {
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.lineNumbers": "interval",
    "editor.rulers": [80],
    "editor.wordWrap": "bounded",
    "editor.wrappingIndent": "indent",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    },
    "editor.renderWhitespace": "boundary",
    "editor.unicodeHighlight.ambiguousCharacters": true,
    "editor.unicodeHighlight.invisibleCharacters": true,
    "files.trimTrailingWhitespace": false
  },
  "[plaintext]":  {
    "editor.unicodeHighlight.ambiguousCharacters": true,
    "editor.unicodeHighlight.invisibleCharacters": true
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.autoIndent": "advanced"
  },
  "[zig]": {
    "editor.defaultFormatter": "ziglang.vscode-zig",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.suggest.insertMode": "replace",
    "editor.stickyScroll.defaultModel": "foldingProviderModel"
  },

  "json.schemaDownload.trustedDomains": {
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://www.schemastore.org/": true,
    "https://developer.microsoft.com/json-schemas/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/catppuccin/vscode/": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true
  },

  "update.mode": "none", // use linux package manager
  "telemetry.enableCrashReporter": false, // deprecated but used by extensions
  "telemetry.enableTelemetry": false, // deprecated but used by extensions
  "telemetry.feedback.enabled": false,
  "telemetry.telemetryLevel": "off",
  "hardhat.telemetry": false,
  "liveshare.presence": true,
  "lldb.suppressUpdateNotifications": true,
  "redhat.telemetry.enabled": false,
  "solidity.telemetry": false,

  // "chat.disableAIFeatures": true, // disable built-in GitHub Copilot
  "chat.mcp.gallery.enabled": true,
  "devin.acp.preferredAgent": "devin-cli",
  "devin.acp.enabledAgents": { "devin-cli": true },
  "devin.allowCascadeAccessGitignoreFiles": true
  // "windsurf.marketplaceExtensionGalleryServiceURL": "https://marketplace.visualstudio.com/_apis/public/gallery",
  // "windsurf.marketplaceGalleryItemURL": "https://marketplace.visualstudio.com/items"
}
